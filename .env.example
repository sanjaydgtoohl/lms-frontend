VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=https://www.lms.dgtoohl.com/api/google/callback

# LMS API (auth, leads, users, etc.)
VITE_API_BASE_URL=https://apislms.dgtoohl.com/api/v1

# Inventory / SSP API (device inventory + location filters)
# GET https://www.staging.dgtoohl.com/api/inventory?page=1&per_page=10&country=India
# Header: X-API-Key: <your-key>
VITE_SSP_API_BASE_URL=https://www.staging.dgtoohl.com/api
VITE_SSP_API_KEY=your-inventory-api-key
# Optional — only if the SSP API also requires bearer auth
# VITE_SSP_BEARER_TOKEN=

VITE_REMOTE_IMAGES_BASE_URL=https://d2nljoxssb7y4b.cloudfront.net
VITE_IMAGE_BASE_URL=/remote-images
VITE_APP_NAME=LMS Frontend
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Learning Management System
VITE_APP_AUTHOR=Mobiyoung

# Development
VITE_DEBUG=true
VITE_LOG_LEVEL=debug
